# Google reCAPTCHA v3
# Get your keys at: https://www.google.com/recaptcha/admin/create
# Choose "reCAPTCHA v3" and register your domain

# Public site key (exposed to browser - safe to share)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your_site_key_here

# Secret key (server-side only - never expose to client)
RECAPTCHA_SECRET_KEY=your_secret_key_here
